---
import AnimatedButton from './AnimatedButton.astro';
import AnimatedInput from './AnimatedInput.astro';
---

<section class="hero" aria-label="Website scanner hero">

  <!-- ── cinematic ambient orbs ── -->
  <div class="orb orb-1" aria-hidden="true"></div>
  <div class="orb orb-2" aria-hidden="true"></div>
  <div class="orb orb-3" aria-hidden="true"></div>

  <!-- ── horizontal grid lines (depth effect) ── -->
  <div class="grid-lines" aria-hidden="true">
    <span></span><span></span><span></span><span></span><span></span>
  </div>

  <!-- ── drifting scan line ── -->
  <div class="hero-scan-line" aria-hidden="true"></div>

  <!-- ── corner brackets ── -->
  <div class="bracket tl" aria-hidden="true"></div>
  <div class="bracket tr" aria-hidden="true"></div>
  <div class="bracket bl" aria-hidden="true"></div>
  <div class="bracket br" aria-hidden="true"></div>

  <div class="hero-inner">
    <div class="hero-content">

      <!-- ── eyebrow badge ── -->
      <div class="hero-badge" role="status" aria-live="polite">
        <span class="badge-ring" aria-hidden="true"></span>
        <span class="badge-dot" aria-hidden="true"></span>
        <span class="badge-label">Website Intelligence Platform</span>
        <span class="badge-shimmer" aria-hidden="true"></span>
      </div>

      <!-- ── hero title ── -->
      <h1 class="hero-title">
        <span class="title-line title-static">Get</span>
        <span class="title-line title-accent">
          <span class="shimmer-text">X-Ray Vision</span>
        </span>
        <span class="title-line title-static">for any Website.</span>
      </h1>

      <!-- ── description ── -->
      <p class="hero-desc">
        Deep-scan any domain in seconds: SSL certificates, DNS records, open ports,
        security headers, tech stack, threats and 30+ more checks.
        <span class="desc-accent">All free. No signup.</span>
      </p>

      <!-- ── scan card with border beam ── -->
      <div class="form-card" id="hero-form-card">
        <!-- animated border beam -->
        <div class="card-beam" aria-hidden="true"></div>
        <!-- top accent line -->
        <div class="card-top-line" aria-hidden="true"></div>

        <form
          name="live-start"
          autocomplete="off"
          action="/check"
          class="hero-form"
          id="hero-form"
          aria-label="Website scanner form"
        >
          <label for="url-input" class="sr-only">Enter a domain, IP, or URL to scan</label>
          <AnimatedInput />
          <AnimatedButton />
        </form>

        <!-- quick suggestions -->
        <div class="suggestions" role="group" aria-label="Example domains">
          <span class="sug-label">Try:</span>
          {['stripe.com','cloudflare.com','github.com','vercel.com'].map((s) => (
            <button class="sug-chip" type="button" data-domain={s} aria-label={`Scan ${s}`}>
              {s}
            </button>
          ))}
        </div>
      </div>

      <!-- ── trust badges ── -->
      <div class="trust-row" aria-label="Key features">
        <div class="trust-item">
          <!-- shield-check icon -->
          <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2L3 7v5c0 5 4 9.4 9 10.5C17 21.4 21 17 21 12V7L12 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>100% Free</span>
        </div>
        <span class="trust-sep" aria-hidden="true"></span>
        <div class="trust-item">
          <!-- lock icon -->
          <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.8"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <span>No Signup</span>
        </div>
        <span class="trust-sep" aria-hidden="true"></span>
        <div class="trust-item">
          <!-- zap icon -->
          <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Instant Results</span>
        </div>
        <span class="trust-sep" aria-hidden="true"></span>
        <div class="trust-item">
          <!-- layers icon -->
          <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2 2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>35+ Checks</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { normalizeAddress } from '../../client/utils/address-type-checker';

  const form     = document.getElementById('hero-form') as HTMLFormElement | null;
  const urlInput = document.getElementById('url-input') as HTMLInputElement | null;

  /* form submit */
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const target = normalizeAddress(urlInput?.value ?? '');
    if (target) window.location.href = `/check/${target}`;
  });

  /* suggestion chips */
  document.querySelectorAll<HTMLButtonElement>('.sug-chip').forEach((chip) => {
    chip.addEventListener('click', () => {
      const domain = chip.dataset.domain ?? '';
      if (urlInput) {
        urlInput.value = domain;
        urlInput.focus();
        /* trigger the shell focused state */
        urlInput.dispatchEvent(new Event('input'));
      }
    });
  });

  /* entrance animation trigger */
  const card = document.getElementById('hero-form-card');
  if (card) {
    requestAnimationFrame(() => card.classList.add('card-enter'));
  }
</script>

<style lang="scss">
  @use '@styles/global.scss' as *;

  /* ── section shell ── */
  .hero {
    position: relative;
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 0 6rem;
    overflow: hidden;
    isolation: isolate;
  }

  /* ── ambient orbs ── */
  .orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
    z-index: 0;
  }
  .orb-1 {
    width: 520px; height: 420px;
    background: radial-gradient(circle, rgba(76,225,211,0.18) 0%, transparent 70%);
    top: -80px; left: 50%;
    transform: translateX(-50%);
    animation: orb-drift-1 12s ease-in-out infinite alternate;
  }
  .orb-2 {
    width: 360px; height: 300px;
    background: radial-gradient(circle, rgba(255,203,154,0.10) 0%, transparent 70%);
    bottom: 0; right: 5%;
    animation: orb-drift-2 15s ease-in-out infinite alternate;
  }
  .orb-3 {
    width: 260px; height: 220px;
    background: radial-gradient(circle, rgba(76,225,211,0.09) 0%, transparent 70%);
    bottom: 10%; left: 2%;
    animation: orb-drift-1 10s ease-in-out infinite alternate-reverse;
  }

  @keyframes orb-drift-1 {
    0%   { transform: translateX(-50%) translateY(0px); }
    100% { transform: translateX(-50%) translateY(30px); }
  }
  @keyframes orb-drift-2 {
    0%   { transform: translateY(0) scale(1); }
    100% { transform: translateY(-20px) scale(1.05); }
  }

  /* ── grid lines (depth) ── */
  .grid-lines {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
    pointer-events: none;
    z-index: 0;

    span {
      display: block;
      height: 1px;
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(76, 225, 211, 0.06) 20%,
        rgba(76, 225, 211, 0.12) 50%,
        rgba(76, 225, 211, 0.06) 80%,
        transparent 100%
      );
    }
  }

  /* ── hero scan line ── */
  .hero-scan-line {
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(76, 225, 211, 0.5) 30%,
      rgba(255, 203, 154, 0.25) 50%,
      rgba(76, 225, 211, 0.5) 70%,
      transparent
    );
    animation: hero-scan 8s linear infinite;
    z-index: 1;
    pointer-events: none;
  }

  @keyframes hero-scan {
    0%   { top: -1px;   opacity: 0; }
    5%   { opacity: 1; }
    95%  { opacity: 0.8; }
    100% { top: 100%;   opacity: 0; }
  }

  /* ── corner brackets ── */
  .bracket {
    position: absolute;
    width: 28px;
    height: 28px;
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    animation: bracket-appear 0.8s cubic-bezier(0.16,1,0.3,1) forwards;
  }
  .bracket.tl { top: 1.5rem; left: 1.5rem; border-top: 1.5px solid rgba(76,225,211,0.5); border-left: 1.5px solid rgba(76,225,211,0.5); animation-delay: 0.2s; }
  .bracket.tr { top: 1.5rem; right: 1.5rem; border-top: 1.5px solid rgba(76,225,211,0.5); border-right: 1.5px solid rgba(76,225,211,0.5); animation-delay: 0.3s; }
  .bracket.bl { bottom: 1.5rem; left: 1.5rem; border-bottom: 1.5px solid rgba(76,225,211,0.5); border-left: 1.5px solid rgba(76,225,211,0.5); animation-delay: 0.4s; }
  .bracket.br { bottom: 1.5rem; right: 1.5rem; border-bottom: 1.5px solid rgba(76,225,211,0.5); border-right: 1.5px solid rgba(76,225,211,0.5); animation-delay: 0.5s; }

  @keyframes bracket-appear {
    from { opacity: 0; transform: scale(0.7); }
    to   { opacity: 0.5; transform: scale(1); }
  }

  /* ── layout ── */
  .hero-inner {
    width: min(820px, 92vw);
    position: relative;
    z-index: 10;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
  }

  /* ── eyebrow badge ── */
  .hero-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.38rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(76, 225, 211, 0.28);
    background: rgba(76, 225, 211, 0.06);
    margin-bottom: 1.75rem;
    overflow: hidden;

    /* entrance */
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up 0.6s cubic-bezier(0.16,1,0.3,1) 0.1s forwards;
  }

  /* pulsing outer ring */
  .badge-ring {
    position: absolute;
    inset: -3px;
    border-radius: inherit;
    border: 1px solid rgba(76,225,211,0.18);
    animation: badge-ring-pulse 2.5s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes badge-ring-pulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50%       { opacity: 0.9; transform: scale(1.02); }
  }

  .badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #4ce1d3;
    box-shadow: 0 0 8px rgba(76,225,211,0.9), 0 0 16px rgba(76,225,211,0.4);
    animation: dot-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes dot-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%       { transform: scale(0.65); opacity: 0.5; }
  }

  .badge-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #4ce1d3;
    position: relative;
    z-index: 1;
  }

  /* shimmer sweep on badge */
  .badge-shimmer {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(90deg, transparent, rgba(76,225,211,0.15) 50%, transparent);
    background-size: 200% 100%;
    animation: badge-sweep 3s linear infinite;
    pointer-events: none;
  }
  @keyframes badge-sweep {
    0%   { background-position: -200% 0; }
    100% { background-position:  200% 0; }
  }

  /* ── hero title ── */
  .hero-title {
    margin: 0 0 1.25rem;
    line-height: 1.08;
    letter-spacing: -0.03em;

    opacity: 0;
    transform: translateY(18px);
    animation: fade-up 0.7s cubic-bezier(0.16,1,0.3,1) 0.2s forwards;
  }

  .title-line {
    display: block;
    font-size: clamp(2.8rem, 6.5vw, 5rem);
    font-weight: 900;
  }

  .title-static {
    color: #e8f4f1;
  }

  .title-accent {
    /* space between lines */
    margin: 0.04em 0;
  }

  /* shimmer gradient title */
  .shimmer-text {
    display: inline-block;
    background: linear-gradient(
      90deg,
      #4ce1d3 0%,
      #8ef5ec 20%,
      #ffffff 40%,
      #ffe0b3 55%,
      #ffffff 65%,
      #8ef5ec 80%,
      #4ce1d3 100%
    );
    background-size: 280% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer-pan 3.5s linear infinite;
  }

  @keyframes shimmer-pan {
    0%   { background-position: 0%   center; }
    100% { background-position: 280% center; }
  }

  /* ── description ── */
  .hero-desc {
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.72;
    color: rgba(209, 232, 226, 0.6);
    max-width: 600px;
    margin: 0 0 2.25rem;

    opacity: 0;
    transform: translateY(14px);
    animation: fade-up 0.65s cubic-bezier(0.16,1,0.3,1) 0.32s forwards;
  }

  .desc-accent {
    color: rgba(76, 225, 211, 0.8);
    font-weight: 600;
  }

  /* ── form card ── */
  .form-card {
    position: relative;
    width: min(640px, 100%);
    padding: 1.5rem;
    border-radius: 20px;
    border: 1px solid rgba(76, 225, 211, 0.16);
    background: rgba(4, 14, 13, 0.82);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    box-shadow:
      0 16px 64px rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(76, 225, 211, 0.05) inset;
    overflow: hidden;
    margin-bottom: 1.75rem;

    /* entrance — slides up */
    opacity: 0;
    transform: translateY(22px) scale(0.98);
    transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1) 0.42s,
                transform 0.7s cubic-bezier(0.16,1,0.3,1) 0.42s;

    &.card-enter {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* rotating border beam */
  .card-beam {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;

    &::before {
      content: '';
      position: absolute;
      top: -50%; left: -50%;
      width: 200%; height: 200%;
      background: conic-gradient(
        from 0deg,
        transparent   0deg,
        rgba(76,225,211,0.5) 30deg,
        rgba(255,203,154,0.3) 60deg,
        transparent   90deg,
        transparent   360deg
      );
      animation: beam-spin 4s linear infinite;
    }

    &::after {
      content: '';
      position: absolute;
      inset: 2px;
      border-radius: inherit;
      background: transparent;
    }
  }

  @keyframes beam-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* top accent line on form card */
  .card-top-line {
    position: absolute;
    top: 0; left: 1.5rem; right: 1.5rem;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(76, 225, 211, 0.55) 35%,
      rgba(255, 203, 154, 0.3) 65%,
      transparent
    );
    background-size: 200% auto;
    animation: top-line-sweep 4s linear infinite;
    z-index: 2;
    pointer-events: none;
  }
  @keyframes top-line-sweep {
    0%   { background-position: 120% center; }
    100% { background-position: -120% center; }
  }

  /* inner form layout */
  .hero-form {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    margin-bottom: 1rem;
  }

  /* ── suggestion chips ── */
  .suggestions {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .sug-label {
    font-size: 0.76rem;
    font-weight: 600;
    color: rgba(209, 232, 226, 0.35);
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .sug-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(76, 225, 211, 0.14);
    background: rgba(76, 225, 211, 0.04);
    color: rgba(209, 232, 226, 0.65);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s ease;

    &:hover {
      color: #4ce1d3;
      background: rgba(76, 225, 211, 0.1);
      border-color: rgba(76, 225, 211, 0.4);
      box-shadow: 0 0 12px rgba(76, 225, 211, 0.14);
      transform: translateY(-1px);
    }

    &:active {
      transform: translateY(0);
    }
  }

  /* ── trust row ── */
  .trust-row {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    justify-content: center;

    opacity: 0;
    transform: translateY(10px);
    animation: fade-up 0.6s cubic-bezier(0.16,1,0.3,1) 0.7s forwards;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    color: rgba(209, 232, 226, 0.52);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;

    &:hover {
      color: rgba(209, 232, 226, 0.8);

      .trust-icon { color: #4ce1d3; }
    }
  }

  .trust-icon {
    color: rgba(76, 225, 211, 0.6);
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  .trust-sep {
    display: block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(76, 225, 211, 0.25);
  }

  /* ── screen reader only ── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ── shared entrance keyframe ── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(var(--ty, 14px)); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── responsive ── */
  @media (max-width: 768px) {
    .hero { padding: 3rem 0 5rem; min-height: auto; }
    .title-line { font-size: clamp(2.2rem, 8vw, 3.5rem); }
    .hero-desc { font-size: 1rem; }
    .form-card { padding: 1.25rem; border-radius: 16px; }
    .trust-row { gap: 0.65rem; }
    .trust-item { font-size: 0.82rem; }
  }

  @media (max-width: 480px) {
    .trust-row { gap: 0.75rem 1.2rem; }
    .trust-sep { display: none; }
    .bracket { display: none; }
  }
</style>

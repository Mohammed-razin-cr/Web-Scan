---
const placeholders = [
  'duck.com',
  'github.com',
  'google.com',
  'x.com',
  'bbc.co.uk',
  'wikipedia.org',
  'openai.com',
];
---

<div class="input-container">
  <div class="input-icon">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
      <path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" stroke="var(--text-tertiary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
  <input
    required
    id="url-input"
    type="text"
    name="url"
    inputmode="url"
    autocapitalize="off"
    autocomplete="off"
    autocorrect="off"
    spellcheck="false"
    placeholder=" "
    class="url-input"
  />
  <div class="placeholder-container">
    <span class="starter" aria-hidden="true">Enter URL:</span>
    {
      placeholders.map((placeholder, index) => (
        <span class={`placeholder ${index === 0 ? 'active' : ''}`} aria-hidden="true">
          {placeholder}
        </span>
      ))
    }
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const placeholders = document.querySelectorAll('.placeholder');
    const starter = document.querySelector('.starter') as HTMLElement;
    const inputField = document.getElementById('url-input') as HTMLInputElement;

    let currentIndex = 0;
    const timeBetweenPlaceholders = 2500;
    let interval: ReturnType<typeof setInterval>;

    const changePlaceholder = () => {
      placeholders.forEach((el, index) => {
        if (index === currentIndex) {
          el.classList.add('active');
          el.classList.remove('inactive');
        } else {
          el.classList.add('inactive');
          el.classList.remove('active');
        }
      });
      currentIndex = (currentIndex + 1) % placeholders.length;
    };

    const startPlaceholderAnimation = () => {
      interval = setInterval(changePlaceholder, timeBetweenPlaceholders);
    };

    const stopPlaceholderAnimation = () => {
      clearInterval(interval);
      if (starter) starter.classList.add('hide');
    };

    inputField.addEventListener('focus', () => {
      stopPlaceholderAnimation();
    });

    inputField.addEventListener('blur', () => {
      if (!inputField.value) {
        startPlaceholderAnimation();
        if (starter) starter.classList.remove('hide');
      }
    });

    inputField.addEventListener('input', () => {
      if (inputField.value) {
        stopPlaceholderAnimation();
      }
    });

    startPlaceholderAnimation();
  });
</script>

<style lang="scss">
  @use '@styles/global.scss' as *;

  .input-container {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--background-secondary);
    border: 1px solid var(--border);
    border-radius: 0.875rem;
    padding: 0.75rem 1rem;
    transition: all 0.25s ease;
    
    &:focus-within {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
      background: var(--background-tertiary);
    }
  }

  .input-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 0.75rem;
    flex-shrink: 0;
  }

  .url-input {
    flex: 1;
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    font-size: 1rem;
    color: var(--text-color);
    font-family: inherit;
    padding: 0.25rem 0;
    
    &::placeholder {
      color: transparent;
    }
  }

  .placeholder-container {
    position: absolute;
    left: 3.25rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    pointer-events: none;
  }

  .starter {
    color: var(--text-tertiary);
    font-size: 1rem;
    transition: opacity 0.3s ease;
    
    &.hide {
      opacity: 0;
    }
  }

  .placeholder {
    position: absolute;
    left: 5.5rem;
    font-size: 1rem;
    color: var(--text-tertiary);
    opacity: 0;
    transform: translateY(-8px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    
    &.active {
      opacity: 1;
      transform: translateY(0);
    }
    
    &.inactive {
      opacity: 0;
      transform: translateY(8px);
    }
  }
</style>
